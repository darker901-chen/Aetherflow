# FFmpeg shared SDK is vendored from a pinned BtbN autobuild for the SRT
# output stage. Binary payload stays out of the repo; the SOP to recreate it
# is in third_party/ffmpeg/SOURCE.md (python tools/fetch_ffmpeg.py).
third_party/ffmpeg/include/
third_party/ffmpeg/lib/
third_party/ffmpeg/bin/
third_party/ffmpeg/VERSION.json
third_party/ffmpeg/_download.zip
# Dear ImGui is vendored from a pinned release for the AetherFlowStudio UI.
# SOP in third_party/imgui/SOURCE.md (python tools/fetch_imgui.py).
third_party/imgui/*
!third_party/imgui/SOURCE.md
